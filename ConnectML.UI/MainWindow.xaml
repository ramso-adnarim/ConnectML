<Window x:Class="ConnectML.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConnectML.UI"
        mc:Ignorable="d"
        Title="MeasurLink PLC Connector" Height="768" Width="1024"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- COLORS -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#136dec"/>
        <SolidColorBrush x:Key="BackgroundDark" Color="#101822"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#1d2835"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2d3b4e"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22c55e"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/> <!-- Slate-400 -->
        <SolidColorBrush x:Key="TextDarker" Color="#64748b"/> <!-- Slate-500 -->

        <!-- Additional Colors from HTML -->
        <SolidColorBrush x:Key="HubIconBg" Color="#33136dec"/> <!-- Primary/20 -->
        <SolidColorBrush x:Key="StopRed" Color="#ef4444"/> <!-- Red-500 -->
        <SolidColorBrush x:Key="StopRedBg" Color="#1Aef4444"/> <!-- Red-500/10 -->
        <SolidColorBrush x:Key="StopRedBorder" Color="#33ef4444"/> <!-- Red-500/20 -->
        <SolidColorBrush x:Key="AmberColor" Color="#f59e0b"/> <!-- Amber-500 -->
        <SolidColorBrush x:Key="PurpleColor" Color="#a855f7"/> <!-- Purple-500 -->
        <SolidColorBrush x:Key="BlueInfo" Color="#60a5fa"/> <!-- Blue-400 -->
        <SolidColorBrush x:Key="TerminalBg" Color="#0d1117"/>

        <!-- STYLES -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/> <!-- rounded-xl -->
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BorderDark}"/>
            <Setter Property="Foreground" Value="#cbd5e1"/> <!-- Slate-300 -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>

        <!-- TextBox Style override -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                         <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0,30,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                          Grid.Column="2"
                                          Focusable="false"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Path Data="M7,10L12,15L17,10H7Z"
                                                      Fill="{StaticResource TextSecondary}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{StaticResource SurfaceDark}"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource BorderDark}"
                                            CornerRadius="8"
                                            Margin="0,4,0,0">
                                        <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Icon & Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <!-- Hub Icon Container -->
                    <Border Width="32" Height="32" CornerRadius="4" Background="{StaticResource HubIconBg}" Margin="0,0,16,0">
                        <Viewbox Width="20" Height="20">
                            <!-- Material Hub Icon -->
                            <Path Fill="{StaticResource PrimaryColor}" Data="M17,16l-4-4V8.82C14.16,8.4,15,7.3,15,6c0-1.66-1.34-3-3-3S9,4.34,9,6c0,1.3,0.84,2.4,2,2.82V12l-4,4H3v5h5v-3.05l4-4.2 l4,4.2V23h5v-5H17z"/>
                        </Viewbox>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MeasurLink PLC Connector" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <!-- Ping Animation -->
                            <Grid Width="12" Height="12" Margin="0,0,6,0">
                                <Ellipse Width="8" Height="8" Fill="#4ade80" Opacity="0.75" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.75" To="0" Duration="0:0:1" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="2.5" Duration="0:0:1" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="2.5" Duration="0:0:1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="SERVICE RUNNING" FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                     <!-- Spacing attribute doesn't exist in standard StackPanel in .NET Framework/Core older versions, using Margins on items instead -->
                    <StackPanel.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
                             <Setter Property="Margin" Value="12,0,0,0"/>
                        </Style>
                    </StackPanel.Resources>

                    <Button Width="Auto" Height="36" Padding="16,0" Background="{StaticResource StopRedBg}" BorderBrush="{StaticResource StopRedBorder}" BorderThickness="1" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                <Path Fill="{StaticResource StopRed}" Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M16,16H8V8h8V16z"/>
                            </Viewbox>
                            <TextBlock Text="Stop Service" Foreground="{StaticResource StopRed}" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button Width="36" Height="36">
                        <Viewbox Width="20" Height="20">
                            <Path Fill="#cbd5e1" Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                        </Viewbox>
                    </Button>

                    <Button Width="36" Height="36">
                        <Viewbox Width="20" Height="20">
                            <Path Fill="#cbd5e1" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: CONFIGURATION -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="{StaticResource BackgroundDark}">
                <StackPanel Margin="24">
                    <StackPanel MaxWidth="896" HorizontalAlignment="Center">

                        <!-- CARD 1: SOURCE -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header -->
                                <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="24,16">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                                                <Path Fill="{StaticResource PrimaryColor}" Data="M20,6h-8l-2-2H4C2.9,4,2.01,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M20,18H4V8h16V18z"/>
                                            </Viewbox>
                                            <TextBlock Text="Source Configuration" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" Style="{StaticResource BadgeStyle}">
                                            <TextBlock Text="Input" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <!-- Body -->
                                <StackPanel Margin="24">
                                    <TextBlock Text="Watch Folder Path (QIF Files)" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Input Field -->
                                        <TextBox Text="C:\QualityData\Incoming\Line_04_Auto" VerticalContentAlignment="Center" Height="40">
                                            <TextBox.Template>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,0,1" CornerRadius="8,0,0,8">
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="8,0" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </TextBox.Template>
                                        </TextBox>
                                        <!-- Browse Button -->
                                        <Button Grid.Column="1" Content="..." Width="48" Height="40" Background="{StaticResource BorderDark}" Foreground="#cbd5e1">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="0,8,8,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ARROW DOWN -->
                        <Grid Margin="0,-12" Panel.ZIndex="10">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource BorderDark}" HorizontalAlignment="Center">
                                <Viewbox Width="20" Height="20">
                                    <Path Fill="{StaticResource TextSecondary}" Data="M7.41,8.59L12,13.17l4.59-4.58L18,10l-6,6l-6-6L7.41,8.59z"/>
                                </Viewbox>
                            </Border>
                        </Grid>

                        <!-- CARD 2: BUSINESS LOGIC -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                            <StackPanel>
                                <!-- Header -->
                                <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="24,16">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                                                <Path Fill="{StaticResource AmberColor}" Data="M18,4H6v2l6.5,6L6,18v2h12v-3h-7l5-5l-5-5h7V4z"/>
                                            </Viewbox>
                                            <TextBlock Text="Business Logic" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" Style="{StaticResource BadgeStyle}">
                                            <TextBlock Text="Process" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <!-- Body -->
                                <Grid Margin="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Write Mode" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Boolean Option -->
                                            <Border Grid.Column="0" Background="#0D136dec" BorderBrush="{StaticResource PrimaryColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,4,0">
                                                <StackPanel>
                                                    <TextBlock Text="Boolean (Bit)" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="Pass/Fail Signal" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Integer Option -->
                                            <Border Grid.Column="1" Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Integer" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="Failure Counter" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Spacer for grid col 1 if needed, layout shows 2 columns in grid but html only uses first one? HTML: grid-cols-2 but only 1 child div used. -->
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ARROW DOWN -->
                        <Grid Margin="0,-12" Panel.ZIndex="10">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource BorderDark}" HorizontalAlignment="Center">
                                <Viewbox Width="20" Height="20">
                                    <Path Fill="{StaticResource TextSecondary}" Data="M7.41,8.59L12,13.17l4.59-4.58L18,10l-6,6l-6-6L7.41,8.59z"/>
                                </Viewbox>
                            </Border>
                        </Grid>

                        <!-- CARD 3: PLC OUTPUT -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                            <StackPanel>
                                <!-- Header -->
                                <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="24,16">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                                                <Path Fill="{StaticResource PurpleColor}" Data="M7.77,6.76L6.23,5.48L0.82,12l5.41,6.52l1.54-1.28L3.42,12L7.77,6.76z M16.23,6.76l4.35,5.24l-4.35,5.24l1.54,1.28 L23.18,12l-5.41-6.52L16.23,6.76z M12,13c0.55,0,1-0.45,1-1V3c0-0.55-0.45-1-1-1s-1,0.45-1,1v9C11,12.55,11.45,13,12,13z"/>
                                            </Viewbox>
                                            <TextBlock Text="PLC Output Configuration" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" Style="{StaticResource BadgeStyle}">
                                            <TextBlock Text="Output" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Body -->
                                <StackPanel Margin="24">
                                    <!-- Protocol -->
                                    <StackPanel Margin="0,0,0,16" MaxWidth="448" HorizontalAlignment="Left">
                                        <TextBlock Text="Communication Protocol" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" Margin="0,0,0,6"/>
                                        <ComboBox SelectedIndex="0" Width="448">
                                            <ComboBoxItem Content="Siemens S7 (Profinet)"/>
                                            <ComboBoxItem Content="Modbus TCP"/>
                                            <ComboBoxItem Content="OPC UA"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Fields -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="IP Address" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <TextBox Text="192.168.0.1" Height="38"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Rack" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <TextBox Text="0" Height="38"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Slot" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <TextBox Text="1" Height="38"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Footer Buttons -->
                                <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0" Padding="24,12" CornerRadius="0,0,12,12">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Test Connection" Style="{StaticResource RoundedButtonStyle}" Background="Transparent" Foreground="{StaticResource TextSecondary}" FontWeight="Medium" Margin="0,0,12,0" Padding="12,6" Height="32"/>
                                        <Button Content="Save Changes" Style="{StaticResource PrimaryButtonStyle}" Padding="16,6" Height="32"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Bottom Padding -->
                        <Border Height="24"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT PANEL: LOGS -->
            <Border Grid.Column="1" Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logs Header -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                    <Path Fill="{StaticResource TextSecondary}" Data="M20,4H4C2.89,4,2,4.89,2,6v12c0,1.11,0.89,2,2,2h16c1.11,0,2-0.89,2-2V6C22,4.89,21.11,4,20,4z M20,18H4V6h16V18z M7.5,15l4.5-4.5L7.5,6L6,7.5l3,3l-3,3L7.5,15z M14,14h5v2h-5V14z"/>
                                </Viewbox>
                                <TextBlock Text="LIVE LOGS" FontSize="14" FontWeight="Bold" Foreground="#e2e8f0"/>
                            </StackPanel>
                            <Button Content="Clear" Style="{StaticResource RoundedButtonStyle}" Background="Transparent" HorizontalAlignment="Right" FontSize="12" Height="Auto" Padding="0"/>
                        </Grid>
                    </Border>

                    <!-- Logs Body -->
                    <ScrollViewer Grid.Row="1" Background="{StaticResource TerminalBg}">
                        <StackPanel Margin="16" TextElement.FontFamily="Consolas, Courier New, Monospace" TextElement.FontSize="12">
                            <!-- Log Item 1 -->
                            <TextBlock Margin="0,0,0,12" TextWrapping="Wrap">
                                <Run Text="[10:42:01.050]" Foreground="{StaticResource TextDarker}"/>
                                <Run Text=" INFO " Foreground="{StaticResource BlueInfo}" FontWeight="Bold"/>
                                <Run Text="Service started successfully." Foreground="{StaticResource TextSecondary}"/>
                            </TextBlock>

                            <!-- Log Item 2 -->
                            <Border BorderBrush="{StaticResource SuccessGreen}" BorderThickness="2,0,0,0" Padding="8,0,0,0" Margin="4,0,0,12">
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="[10:42:05.410]" Foreground="{StaticResource TextDarker}"/>
                                    <Run Text=" WRITE " Foreground="#4ade80" FontWeight="Bold"/> <!-- Green-400 -->
                                    <Run Text="PLC Write -> TRUE (PASS)" Foreground="{StaticResource TextSecondary}"/>
                                </TextBlock>
                            </Border>

                            <!-- Log Item 3 -->
                            <TextBlock Margin="0,0,0,12" TextWrapping="Wrap">
                                <Run Text="[10:42:05.350]" Foreground="{StaticResource TextDarker}"/>
                                <Run Text=" PARSE " Foreground="#c084fc" FontWeight="Bold"/> <!-- Purple-400 -->
                                <Run Text="Processing QIF..." Foreground="{StaticResource TextSecondary}"/>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Logs Footer -->
                    <Border Grid.Row="2" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0" Padding="12,8">
                        <Grid>
                            <TextBlock Text="Version 2.4.1" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessGreen}" Margin="0,0,6,0"/>
                                <TextBlock Text="Online" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
