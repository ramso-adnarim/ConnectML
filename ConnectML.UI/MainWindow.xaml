<Window x:Class="ConnectML.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConnectML.UI"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="ConnectML - V1.1.0" Height="700" Width="980"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterScreen"
        MinWidth="500"
        MinHeight="685"
        MouseDown="Window_MouseDown" WindowStyle="None">

    <Window.Resources>
        <!-- COLORS -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#136dec"/>
        <SolidColorBrush x:Key="BackgroundDark" Color="#101822"/>
        <SolidColorBrush x:Key="SurfaceDark" Color="#1d2835"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2d3b4e"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22c55e"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/>
        <SolidColorBrush x:Key="TextDarker" Color="#64748b"/>

        <SolidColorBrush x:Key="HubIconBg" Color="#33136dec"/>
        <SolidColorBrush x:Key="StopRed" Color="#ef4444"/>
        <SolidColorBrush x:Key="StopRedBg" Color="#1Aef4444"/>
        <SolidColorBrush x:Key="StopRedBorder" Color="#33ef4444"/>

        <SolidColorBrush x:Key="StartGreen" Color="#22c55e"/>
        <SolidColorBrush x:Key="StartGreenBg" Color="#1A22c55e"/>
        <SolidColorBrush x:Key="StartGreenBorder" Color="#3322c55e"/>

        <SolidColorBrush x:Key="AmberColor" Color="#f59e0b"/>
        <SolidColorBrush x:Key="PurpleColor" Color="#a855f7"/>
        <SolidColorBrush x:Key="BlueInfo" Color="#60a5fa"/>
        <SolidColorBrush x:Key="TerminalBg" Color="#0d1117"/>

        <!-- STYLES -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceDark}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#25354a"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#33136dec"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkExpanderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#25354a"/> <!-- Slightly lighter than SurfaceDark to give feedback -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BorderDark}"/>
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0,30,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                          Grid.Column="2"
                                          Focusable="false"
                                          ClickMode="Press"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Viewbox Width="12" Height="12" Margin="0,0,16,0" 
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Center">
                                                    <Grid Width="8" Height="8">
                                                        <Path Data="M7,10L12,15L17,10H7Z"
                                                              Fill="{StaticResource TextSecondary}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,0,0"
                                                              Stretch="Uniform"/>
                                                    </Grid>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{StaticResource SurfaceDark}"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource BorderDark}"
                                            CornerRadius="8"
                                            Margin="0,4,0,0">
                                        <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="BlinkAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.3" Duration="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1.0" To="1.2" Duration="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1.0" To="1.2" Duration="0:0:0.8"/>
        </Storyboard>

        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle" Background="#4b5563" CornerRadius="4" BorderThickness="0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#6b7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Background" Value="#2d3b4e"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}" Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}" Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="18,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Menu Hamburger -->
                    <ColumnDefinition Width="Auto"/> <!-- Icon & Title -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Leftmost: Hamburger Menu -->
                <Button x:Name="BtnHamburger" Grid.Column="0" Width="36" Height="36" Margin="0,0,12,0" 
                        Click="BtnHamburger_Click" ToolTip="Alternar Painel de Configurações" Style="{StaticResource RoundedButtonStyle}">
                    <Viewbox Width="18" Height="18">
                        <Path Fill="#cbd5e1" Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z" Stretch="Uniform"/>
                    </Viewbox>
                </Button>

                <!-- Left: Icon & Title -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,0">
                    <Border Width="45" Height="45" CornerRadius="4" Background="Transparent" Margin="0,0,16,0">
                        <Image Source="/Assets/logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ConnectML" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <Button x:Name="BtnSecurityLock" Width="22" Height="22" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Click="BtnSecurityLock_Click" ToolTip="Segurança da Aplicação (Desbloqueado)" Style="{StaticResource RoundedButtonStyle}" Background="Transparent">
                                <Viewbox Width="12" Height="12">
                                    <Path x:Name="PathPadlock" Fill="{StaticResource TextSecondary}" 
                                          Data="M18,8H10V6A2,2 0 0,1 12,4C13.1,4 14,4.9 14,6H16A4,4 0 0,0 12,2A4,4 0 0,0 8,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M12,17A2,2 0 1,1 14,15A2,2 0 0,1 12,17Z" 
                                          Stretch="Uniform"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Grid Width="12" Height="12" Margin="0,0,6,0">
                                <Ellipse x:Name="StatusIndicator" Width="8" Height="8" Fill="{StaticResource TextSecondary}" Opacity="1" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <TextBlock x:Name="TxtStatus" Text="PARADO" FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
                            <Setter Property="Margin" Value="12,0,0,0"/>
                        </Style>
                    </StackPanel.Resources>

                    <CheckBox x:Name="ChkAutoStart" Content="Reinício Automático" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="12,0,0,0" ToolTip="Inicia o serviço automaticamente ao abrir o aplicativo se ele foi encerrado rodando da última vez."/>

                    <Button x:Name="BtnStartStop" Width="70" Height="36" Padding="16,0" Click="BtnStartStop_Click"
                            Background="{StaticResource StartGreenBg}" BorderBrush="{StaticResource StartGreenBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center">
                                <!-- O Grid simula a área original do ícone (viewport) -->
                                <Grid Width="14" Height="12">
                                    <Path x:Name="IconStartStop" 
                                      Fill="{StaticResource StartGreen}" 
                                      Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center" 
                                      Stretch="Uniform" Cursor=""/>
                                </Grid>
                            </Viewbox>
                            <TextBlock x:Name="TxtStartStop" Text="Iniciar" Foreground="{StaticResource StartGreen}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnMinimize" Width="30" Height="30" Margin="12,0,0,0" ToolTip="Minimizar (Tray)" Click="BtnMinimize_Click" Style="{StaticResource RoundedButtonStyle}">
                        <Viewbox Width="15" Height="15">
                            <Grid Width="20" Height="20">
                                <Path Fill="#cbd5e1" 
                                      Data="M5,11H19V13H5V11Z"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"/>
                            </Grid>
                        </Viewbox>
                    </Button>

                    <Button x:Name="BtnClose" Width="25" Height="25" Margin="12,0,0,0" Click="BtnClose_Click" ToolTip="Fechar" Style="{StaticResource RoundedButtonStyle}" Cursor="Hand">
                         <Button.Resources>
                             <Style TargetType="Border">
                                 <Setter Property="CornerRadius" Value="8"/>
                             </Style>
                         </Button.Resources>
                        <Viewbox Width="12" Height="12">
                            <Path x:Name="IconClose" 
                                  Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                  Fill="#cbd5e1" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"
                                  Stretch="Uniform" Cursor=""/>
                        </Viewbox>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BtnClose" Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="#1Aef4444" Duration="0:0:0.1"/>
                                        <ColorAnimation Storyboard.TargetName="IconClose" Storyboard.TargetProperty="(Path.Fill).(SolidColorBrush.Color)" To="#ef4444" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BtnClose" Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="#2d3b4e" Duration="0:0:0.1"/>
                                        <ColorAnimation Storyboard.TargetName="IconClose" Storyboard.TargetProperty="(Path.Fill).(SolidColorBrush.Color)" To="#cbd5e1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="564" MinWidth="350" x:Name="ColConfig"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" x:Name="ColLogs" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: CONFIGURATION -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="{StaticResource BackgroundDark}">
                <StackPanel Margin="10,10,10,10" x:Name="PnlConfiguration">
                    <StackPanel MaxWidth="896" HorizontalAlignment="Stretch">

                        <!-- CARD 1: SOURCE -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1">
                                    <Button x:Name="BtnToggleSource" Click="BtnToggleSource_Click" Style="{StaticResource DarkExpanderButtonStyle}" Padding="20,5" Height="40">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Viewbox Width="24" Height="20" Margin="0,0,8,0">
                                                    <Path Fill="{StaticResource PrimaryColor}" Data="M20,6h-8l-2-2H4C2.9,4,2.01,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M20,18H4V8h16V18z"/>
                                                </Viewbox>
                                                <TextBlock Text="Arquivo de entrada" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Border Style="{StaticResource BadgeStyle}" Margin="0,2,8,2">
                                                    <TextBlock Text="Entrada" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" TextAlignment="Center"/>
                                                </Border>
                                                <Path x:Name="IconToggleSource" Fill="{StaticResource TextSecondary}" Data="M7,10L12,15L17,10H7Z" Stretch="Uniform" Width="12" Height="12" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </Border>
                                <StackPanel x:Name="PnlSourceBody" Margin="24,12">
                                    <TextBlock Text="Diretório para monitorar:" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtSourcePath" Text="C:\Mitutoyo\ConnectML\QIF" VerticalContentAlignment="Center" Height="30"/>
                                        <Button Grid.Column="1" Margin="8,0,0,0" Width="32" x:Name="BtnBrowseFolder" Click="BtnBrowseFolder_Click" 
                                                Style="{StaticResource RoundedButtonStyle}" Height="30" ToolTip="Selecionar Pasta">
                                            <Viewbox Width="16" Height="16">
                                                <Path Fill="{StaticResource TextSecondary}" 
                                                      Data="M20,6h-8l-2-2H4C2.9,4,2.01,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M20,18H4V8 h16V18z" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Stretch="Uniform" Cursor=""/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ARROW DOWN -->
                        <Grid Margin="0,-12" Panel.ZIndex="10"/>

                        <!-- CARD 2: BUSINESS LOGIC -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                            <StackPanel>
                                <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1">
                                    <Button x:Name="BtnToggleLogic" Click="BtnToggleLogic_Click" Style="{StaticResource DarkExpanderButtonStyle}" Padding="24,5" Height="40">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                                                    <Path Fill="{StaticResource AmberColor}" Data="M18,4H6v2l6.5,6L6,18v2h12v-3h-7l5-5l-5-5h7V4z"/>
                                                </Viewbox>
                                                <TextBlock Text="Configuração" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Border Style="{StaticResource BadgeStyle}" Margin="0,2,8,2">
                                                    <TextBlock Text="Processamento" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}"/>
                                                </Border>
                                                <Path x:Name="IconToggleLogic" Fill="{StaticResource TextSecondary}" Data="M7,10L12,15L17,10H7Z" Stretch="Uniform" Width="12" Height="12" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </Border>
                                <Grid x:Name="PnlLogicBody" Margin="24, 12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <TextBlock Text="Campos de Configuração" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" VerticalAlignment="Center"/>
                                            <Button x:Name="BtnAddConfig" Click="BtnAddConfig_Click" Width="30" Height="30" HorizontalAlignment="Right" Style="{StaticResource RoundedButtonStyle}" ToolTip="Adicionar Campo">
                                                <Viewbox Width="12" Height="12">
                                                    <Path Fill="{StaticResource TextSecondary}" Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Stretch="Uniform"/>
                                                </Viewbox>
                                            </Button>
                                        </Grid>
                                        
                                        <ItemsControl x:Name="ItemsConfigList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <ComboBox SelectedValue="{Binding FieldType, Mode=TwoWay}"
                                                                  SelectedValuePath="Tag"
                                                                  Height="38" VerticalAlignment="Center"
                                                                  SelectionChanged="CmbFieldType_SelectionChanged">
                                                            <ComboBoxItem Content="Verdadeiro/Falso" Tag="Boolean"/>
                                                            <ComboBoxItem Content="Contador" Tag="Numeric"/>
                                                            <ComboBoxItem Content="Nome da Peça (Part Number)" Tag="String"/>
                                                        </ComboBox>
                                                                  
                                                        <Button Grid.Column="1" Click="BtnRemoveConfig_Click" Width="30" Height="30" Margin="8,0,0,0" Style="{StaticResource RoundedButtonStyle}" Background="{StaticResource StopRedBg}" Foreground="{StaticResource StopRed}" BorderBrush="{StaticResource StopRedBorder}" BorderThickness="1" VerticalAlignment="Center" Visibility="{Binding RemoveButtonVisibility}" ToolTip="Remover Campo">
                                                            <Viewbox Width="12" Height="12">
                                                                <Path Fill="{StaticResource StopRed}" Data="M19,13H5V11H19V13Z" Stretch="Uniform"/>
                                                            </Viewbox>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Inline Webhook warning -->
                                        <TextBlock x:Name="TxtInlineWarning" Foreground="{StaticResource StopRed}" FontSize="12" Margin="0,8,0,0" Visibility="Collapsed" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ARROW DOWN -->
                        <Grid Margin="0,-12" Panel.ZIndex="10"/>

                        <!-- CARD 3: PLC OUTPUT -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                            <StackPanel>
                                <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1">
                                    <Button x:Name="BtnToggleIntegration" Click="BtnToggleIntegration_Click" Style="{StaticResource DarkExpanderButtonStyle}" Padding="24,5" Height="40">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                                                    <Path Fill="{StaticResource PurpleColor}" Data="M7.77,6.76L6.23,5.48L0.82,12l5.41,6.52l1.54-1.28L3.42,12L7.77,6.76z M16.23,6.76l4.35,5.24l-4.35,5.24l1.54,1.28 L23.18,12l-5.41-6.52L16.23,6.76z M12,13c0.55,0,1-0.45,1-1V3c0-0.55-0.45-1-1-1s-1,0.45-1,1v9C11,12.55,11.45,13,12,13z"/>
                                                </Viewbox>
                                                <TextBlock Text="Integração" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Border Style="{StaticResource BadgeStyle}" Margin="0,2,8,2">
                                                    <TextBlock Text="Saída" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}"/>
                                                </Border>
                                                <Path x:Name="IconToggleIntegration" Fill="{StaticResource TextSecondary}" Data="M7,10L12,15L17,10H7Z" Stretch="Uniform" Width="12" Height="12" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </Border>

                                <StackPanel x:Name="PnlIntegrationBody" Margin="24,12">
                                    <StackPanel Margin="0,0,0,16" MaxWidth="448" HorizontalAlignment="Left">
                                        <TextBlock Text="Protocolo de Comunicação" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="CmbProtocol" 
                                                  SelectedIndex="1" 
                                                  Width="448" 
                                                  Height="28" 
                                                  VerticalAlignment="Center"
                                                  SelectionChanged="CmbProtocol_SelectionChanged">
                                            <ComboBoxItem Content="Siemens S7 (Profinet)"/>
                                            <ComboBoxItem Content="Webhook REST Genérico"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- SIEMENS S7 Fields -->
                                    <Grid Margin="0,0,0,16" x:Name="PnlSiemensConfig" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Endereço IP" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtIp" Text="192.168.0.1" Height="38"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Rack" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtRack" Text="0" Height="38"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Slot" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtSlot" Text="1" Height="38"/>
                                        </StackPanel>
                                    </Grid>

                                    <UniformGrid x:Name="PnlSiemensDbConfig" Visibility="Collapsed" Margin="0,0,0,16" SizeChanged="PnlSiemensDbConfig_SizeChanged">
                                        <!-- DB (Booleana) -->
                                        <StackPanel x:Name="GrpDbBool" Margin="0,0,12,12">
                                            <TextBlock Text="DB (Booleana)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="TxtDbBool" Text="DB10.0" Height="38" ToolTip="Endereço para OK/NOK" Grid.Column="0" Margin="0,0,4,0"/>
                                                <Button x:Name="BtnTestBool" Grid.Column="1" Width="38" Height="38" Style="{StaticResource RoundedButtonStyle}" ToolTip="Testar (Toggle)" Click="BtnTestBool_Click">
                                                    <Viewbox Width="16" Height="16">
                                                        <Path Fill="{StaticResource TextSecondary}" Data="M17,7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7M17,15A3,3 0 0,1 14,12A3,3 0 0,1 17,9A3,3 0 0,1 20,12A3,3 0 0,1 17,15Z" Stretch="Uniform"/>
                                                    </Viewbox>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- DB (Inteira) -->
                                        <StackPanel x:Name="GrpDbInt" Margin="0,0,12,12">
                                            <TextBlock Text="DB (Inteira)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="TxtDbInt" Text="DB10.2" Height="38" ToolTip="Endereço para contador" Grid.Column="0" Margin="0,0,4,0"/>
                                                <Button x:Name="BtnTestInt" Grid.Column="1" Width="38" Height="38" Style="{StaticResource RoundedButtonStyle}" ToolTip="Testar (Incrementar)" Click="BtnTestInt_Click">
                                                    <Viewbox Width="16" Height="16">
                                                        <Path Fill="{StaticResource TextSecondary}" Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Stretch="Uniform"/>
                                                    </Viewbox>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- DB (PartNumber) -->
                                        <StackPanel x:Name="GrpDbPartNumber" Margin="0,0,12,12">
                                            <TextBlock Text="DB (PartNumber)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="TxtDbPartNumber" Text="DB10.6" Height="38" ToolTip="Endereço para String do PartNumber" Grid.Column="0" Margin="0,0,4,0"/>
                                                <Button x:Name="BtnTestPartNumber" Grid.Column="1" Width="38" Height="38" Style="{StaticResource RoundedButtonStyle}" ToolTip="Testar String (Alternar)" Click="BtnTestPartNumber_Click">
                                                    <Viewbox Width="16" Height="16">
                                                        <Path Fill="{StaticResource TextSecondary}" Data="M17,7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7M17,15A3,3 0 0,1 14,12A3,3 0 0,1 17,9A3,3 0 0,1 20,12A3,3 0 0,1 17,15Z" Stretch="Uniform"/>
                                                    </Viewbox>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- DB (Status) -->
                                        <StackPanel x:Name="GrpDbStatus" Margin="0,0,12,12">
                                            <TextBlock Text="DB (Status)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="TxtDbStatus" Text="DB10.4" Height="38" ToolTip="Endereço para handshake" Grid.Column="0" Margin="0,0,4,0"/>
                                                <Button x:Name="BtnTestStatus" Grid.Column="1" Width="38" Height="38" Style="{StaticResource RoundedButtonStyle}" ToolTip="Testar (Ler Status)" Click="BtnTestStatus_Click">
                                                    <Viewbox Width="16" Height="16">
                                                        <Path Fill="{StaticResource TextSecondary}" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Stretch="Uniform"/>
                                                    </Viewbox>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </UniformGrid>

                                    <!-- WEBHOOK REST Fields -->
                                    <StackPanel x:Name="PnlWebhookConfig">
                                        <!-- INBOUND CONFIG -->
                                        <TextBlock Text="Configuração Local (Inbound)" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" Margin="0,0,0,12"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Porta Servidor Kestrel" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="TxtInboundPort" Text="5000" Height="38" ToolTip="Porta em que o software escuta os comandos"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Repasse COM Virtual (QIF)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="CmbVirtualCom" Height="38"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0" Margin="0,8,0,16"/>

                                        <!-- OUTBOUND CONFIG -->
                                        <TextBlock Text="Webhook de Saída (Outbound JSON)" FontSize="14" FontWeight="Medium" Foreground="#cbd5e1" Margin="0,0,0,12"/>
                                        
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="URL do Endpoint" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="TxtWebhookUrl" Text="https://" Height="38"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Método HTTP" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="CmbWebhookVerb" Height="38">
                                                    <ComboBoxItem Content="POST"/>
                                                    <ComboBoxItem Content="PUT"/>
                                                    <ComboBoxItem Content="PATCH"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Authentication -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="2.5*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Tipo de Autenticação" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="CmbAuthType" Height="38" SelectionChanged="CmbAuthType_SelectionChanged">
                                                    <ComboBoxItem Content="None"/>
                                                    <ComboBoxItem Content="Basic Auth"/>
                                                    <ComboBoxItem Content="Bearer Token"/>
                                                    <ComboBoxItem Content="HMAC (Secret)"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel x:Name="PnlAuthToken" Grid.Column="2" Visibility="Collapsed">
                                                <TextBlock Text="Token / Password / Secret" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="TxtAuthToken" Height="38"/>
                                                <StackPanel x:Name="PnlHmacHeader" Margin="0,8,0,0" Visibility="Collapsed">
                                                    <TextBlock Text="Nome do Header HMAC (Opcional)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="TxtHmacHeaderName" Height="38" ToolTip="Deixe vazio para o padrão do GitHub Actions"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Custom Headers -->
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Headers Customizados" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <DataGrid x:Name="DgCustomHeaders" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True"
                                                      Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource BorderDark}" 
                                                      RowBackground="{StaticResource BackgroundDark}" AlternatingRowBackground="{StaticResource SurfaceDark}"
                                                      HorizontalGridLinesBrush="{StaticResource BorderDark}" VerticalGridLinesBrush="{StaticResource BorderDark}"
                                                      GridLinesVisibility="All" Foreground="{StaticResource TextPrimary}" Height="120" RowHeaderWidth="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Chave (Header-Name)" Binding="{Binding Key}" Width="*"/>
                                                    <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>

                                        <!-- Payload Template -->
                                        <StackPanel Margin="0,0,0,8">
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Template do Payload (Motor Liquid)" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                                <Button Click="BtnToggleWordWrap_Click" ToolTip="Alternar Quebra de Linha Automática" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Style="{StaticResource RoundedButtonStyle}" Height="20" Width="20" Padding="0">
                                                    <Viewbox Width="12" Height="12">
                                                        <Path Fill="{StaticResource TextSecondary}" Data="M19,10H6v-3l-4,4l4,4V12h11c1.1,0,2,0.9,2,2s-0.9,2-2,2H7v2h12c2.2,0,4-1.8,4-4S21.2,10,19,10z"/>
                                                    </Viewbox>
                                                </Button>
                                            </Grid>
                                            <Border BorderBrush="#334155" BorderThickness="1" Background="#0F172A">
                                                <Grid Margin="4">
                                                    <avalonEdit:TextEditor x:Name="TxtPayloadTemplate" 
                                                                           Height="112" 
                                                                           HorizontalScrollBarVisibility="Auto"
                                                                           VerticalScrollBarVisibility="Auto"
                                                                           WordWrap="False"
                                                                           ShowLineNumbers="False"
                                                                           SyntaxHighlighting="JavaScript"
                                                                           FontFamily="Consolas" 
                                                                           FontSize="13" 
                                                                           Background="Transparent" 
                                                                           Foreground="#D4D4D4" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Height="24"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- SPLITTER (Thumb-based for stable pixel-to-star resizing without flickering) -->
            <Thumb x:Name="LogsSplitter" Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Cursor="SizeWE" DragDelta="LogsSplitter_DragDelta">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource BorderDark}"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- RIGHT PANEL: LOGS CONTAINER -->
            <Grid Grid.Column="2" x:Name="PnlLogsContainer">
                
                <!-- EXPANDED VIEW -->
                <Border x:Name="PnlLogsExpanded" Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="16,12">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnToggleLogs" Click="BtnToggleLogs_Click" Margin="0,0,8,0" 
                                            Style="{StaticResource RoundedButtonStyle}" Width="24" Height="24" Background="Transparent">
                                        <Viewbox Width="10" Height="10">
                                            <Path Fill="{StaticResource TextSecondary}" Data="M8.59,16.59L13.17,12L8.59,7.41L10,6l6,6l-6,6L8.59,16.59z" Stretch="Uniform" Width="10" Height="10"/>
                                        </Viewbox>
                                    </Button>
                                   
                                    <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                        <Path Fill="{StaticResource TextSecondary}" Data="M20,4H4C2.89,4,2,4.89,2,6v12c0,1.11,0.89,2,2,2h16c1.11,0,2-0.89,2-2V6C22,4.89,21.11,4,20,4z M20,18H4V6h16V18z M7.5,15l4.5-4.5L7.5,6L6,7.5l3,3l-3,3L7.5,15z M14,14h5v2h-5V14z" Stretch="Uniform" Width="10" Height="10"/>
                                    </Viewbox>
                                    <TextBlock Text="LOG" FontSize="14" FontWeight="Bold" Foreground="#e2e8f0" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Right">
                                    <Button Click="BtnCopyLogs_Click" ToolTip="Copiar todo o registro" Style="{StaticResource RoundedButtonStyle}" Background="Transparent" Height="Auto" Padding="6,2" Margin="0,0,4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Fill="{StaticResource TextSecondary}" Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" Stretch="Uniform" Width="10" Height="10" Margin="0,0,4,0"/>
                                            <TextBlock Text="Copiar" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnClearLogs" Click="BtnClearLogs_Click" ToolTip="Limpar registros" Style="{StaticResource RoundedButtonStyle}" Background="Transparent" Height="Auto" Margin="0,6,0,0"  Padding="6,2">
                                        <TextBlock Text="Limpar" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <RichTextBox x:Name="TxtLogsRich" Grid.Row="1" Background="{StaticResource TerminalBg}" 
                                     BorderThickness="0" FontFamily="Consolas, Courier New, Monospace" FontSize="12"
                                     IsReadOnly="True" IsDocumentEnabled="True"
                                     Padding="16" VerticalScrollBarVisibility="Auto">
                            <FlowDocument x:Name="DocLogs" LineHeight="7" PagePadding="0"/>
                        </RichTextBox>

                        <Border Grid.Row="2" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0" Padding="12,8">
                            <Grid>
                                <TextBlock Text="Versão 1.0.0" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="{StaticResource TextSecondary}" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtFooterStatus" Text="Offline" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- COLLAPSED VIEW (SIDE TAB) -->
                <Border x:Name="PnlLogsCollapsed" Background="{StaticResource SurfaceDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1,0,0,0" 
                        Visibility="Collapsed" Width="32" HorizontalAlignment="Right">
                    <Button Click="BtnToggleLogs_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Style="{StaticResource RoundedButtonStyle}">
                         <Grid>
                            <Grid.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </Grid.LayoutTransform>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="VER LOG" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                                <Viewbox Width="10" Height="10">
                                    <Path Fill="{StaticResource TextSecondary}" Data="M10,6L8.59,7.41L13.17,12l-4.58,4.59L10,18l6-6L10,6z M6,6h2v12H6V6z" Stretch="Uniform" Width="12" Height="12"/>
                                </Viewbox>
                            </StackPanel>
                        </Grid>
                    </Button>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
