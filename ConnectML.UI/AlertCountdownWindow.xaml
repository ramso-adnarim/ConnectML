<Window x:Class="ConnectML.UI.AlertCountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Atenção" Height="200" Width="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize">
    <Border Background="#1e293b" BorderBrush="#ef4444" BorderThickness="1.5" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.5" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header (Aviso) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                      Fill="#ef4444" Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Falha na conexão" FontSize="14" FontWeight="Bold" Foreground="#f1f5f9" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Body (Contagem Regressiva) -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtCountdown" Text="Tentando novamente em 6s..." FontSize="16" Foreground="#cbd5e1" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Certifique-se de que o CLP está online e no IP correto." FontSize="10" Foreground="#64748b" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
            
            <!-- Actions -->
            <Button x:Name="BtnCancel" Grid.Row="2" Content="Cancelar tentativa" Height="32" Width="150" 
                    Background="#334155" Foreground="#f1f5f9" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#334155"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#475569"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
