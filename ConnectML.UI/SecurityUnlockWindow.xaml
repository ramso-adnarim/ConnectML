<Window x:Class="ConnectML.UI.SecurityUnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desbloquear Segurança" Height="265" Width="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        FocusManager.FocusedElement="{Binding ElementName=TxtUsername}">
    
    <Window.Resources>
        <!-- Style for inputs to look dark and premium -->
        <Style x:Key="ModalInputStyle" TargetType="Control">
            <Setter Property="Background" Value="#0f172a"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource ModalInputStyle}"/>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource ModalInputStyle}"/>
    </Window.Resources>

    <Border Background="#1e293b" BorderBrush="#60a5fa" BorderThickness="1.5" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.5" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Body Inputs -->
                <RowDefinition Height="Auto"/> <!-- Error MSG -->
                <RowDefinition Height="Auto"/> <!-- Actions -->
            </Grid.RowDefinitions>
            
            <!-- Header (Acesso) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z" 
                      Fill="#60a5fa" Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Liberar acesso" FontSize="14" FontWeight="Bold" Foreground="#f1f5f9" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Body Inputs -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <!-- Username -->
                <TextBlock Text="Nome de Usuário (Login):" FontSize="11" Foreground="#94a3b8" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUsername" Margin="0,0,0,10" VerticalContentAlignment="Center" KeyDown="Txt_KeyDown"/>
                
                <!-- Password -->
                <TextBlock Text="Senha:" FontSize="11" Foreground="#94a3b8" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" VerticalContentAlignment="Center" KeyDown="Txt_KeyDown"/>
            </StackPanel>
            
            <!-- Error MSG -->
            <TextBlock x:Name="TxtError" Grid.Row="2" Text="" Foreground="#ef4444" FontSize="11" FontWeight="SemiBold" 
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,6" Visibility="Collapsed" Height="16"/>
            
            <!-- Actions -->
            <Grid Grid.Row="3" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Cancel Button -->
                <Button x:Name="BtnCancel" Grid.Column="0" Content="Cancelar" Height="32" 
                        Background="#334155" Foreground="#f1f5f9" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#334155"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#475569"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Confirm Button -->
                <Button x:Name="BtnConfirm" Grid.Column="2" Content="Confirmar" Height="32" 
                        Background="#136dec" Foreground="#ffffff" BorderThickness="0" Cursor="Hand" Click="BtnConfirm_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#136dec"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1d4ed8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
